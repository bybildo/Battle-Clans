<Page x:Class="Battle_Clans.Windows.ShopPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="ShopPage" Height="800" Width="1400"
      Background="#F0F0F0">

    <Page.Resources>
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="15" ShadowDepth="3" Opacity="0.1" Color="Black"/>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ShopCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Effect" Value="{StaticResource ShadowEffect}"/>
            <Setter Property="Width" Value="160"/>
        </Style>

        <Style x:Key="BuyButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="МАГАЗИН" FontSize="40" FontWeight="Heavy" Foreground="#333" HorizontalAlignment="Center"/>
                <TextBlock x:Name="GoldText" Text="Золото: 0" FontSize="24" FontWeight="Bold" Foreground="#FFC107" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>

            <Button Content="У БІЙ ⚔️" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="18"
                    Padding="20,10" BorderThickness="0" Cursor="Hand"
                    Click="OnNextBattleClick">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Margin="10">
                <StackPanel>
                    <TextBlock Text="НАЙМ ВІЙСЬКА (5 Макс)" Style="{StaticResource SectionHeaderStyle}"/>

                    <WrapPanel HorizontalAlignment="Center">
                        <Border Style="{StaticResource ShopCardStyle}">
                            <StackPanel>
                                <Rectangle Height="80" Fill="#448AFF" RadiusX="5" RadiusY="5" Margin="0,0,0,5"/>
                                <TextBlock Text="Knight" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                <TextBlock Text="50 gold" Foreground="Gray" HorizontalAlignment="Center"/>
                                <Button Content="НАЙНЯТИ" Background="#1976D2" Tag="Knight" Click="OnBuyUnitClick" Style="{StaticResource BuyButtonStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ShopCardStyle}">
                            <StackPanel>
                                <Rectangle Height="80" Fill="#66BB6A" RadiusX="5" RadiusY="5" Margin="0,0,0,5"/>
                                <TextBlock Text="Archer" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                <TextBlock Text="60 gold" Foreground="Gray" HorizontalAlignment="Center"/>
                                <Button Content="НАЙНЯТИ" Background="#388E3C" Tag="Archer" Click="OnBuyUnitClick" Style="{StaticResource BuyButtonStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ShopCardStyle}">
                            <StackPanel>
                                <Rectangle Height="80" Fill="#AB47BC" RadiusX="5" RadiusY="5" Margin="0,0,0,5"/>
                                <TextBlock Text="Mage" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                <TextBlock Text="60 gold" Foreground="Gray" HorizontalAlignment="Center"/>
                                <Button Content="НАЙНЯТИ" Background="#7B1FA2" Tag="Mage" Click="OnBuyUnitClick" Style="{StaticResource BuyButtonStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ShopCardStyle}">
                            <StackPanel>
                                <Rectangle Height="80" Fill="#FF7043" RadiusX="5" RadiusY="5" Margin="0,0,0,5"/>
                                <TextBlock Text="Horseman" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                <TextBlock Text="70 gold" Foreground="Gray" HorizontalAlignment="Center"/>
                                <Button Content="НАЙНЯТИ" Background="#E64A19" Tag="HorseWarrior" Click="OnBuyUnitClick" Style="{StaticResource BuyButtonStyle}"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>

            <Rectangle Grid.Column="1" Width="2" Fill="#E0E0E0" Margin="0,20"/>

            <ScrollViewer Grid.Column="2" Margin="10">

                <StackPanel>
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="АРСЕНАЛ" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                        <TextBlock x:Name="SelectedDecoratorText" Text="Оберіть предмет..." FontSize="14" Foreground="#D32F2F" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>

                    <WrapPanel HorizontalAlignment="Center">
                        <Border Style="{StaticResource ShopCardStyle}">
                            <StackPanel>
                                <Rectangle Height="60" Fill="#FFCCBC" RadiusX="5" RadiusY="5" Margin="0,0,0,5"/>
                                <TextBlock Text="Fire Power" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="50 gold" Foreground="Gray" HorizontalAlignment="Center"/>
                                <Button Content="ОБРАТИ" Background="#FF5722" Tag="FirePower" Click="OnSelectItemClick" Style="{StaticResource BuyButtonStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ShopCardStyle}">
                            <StackPanel>
                                <Rectangle Height="60" Fill="#CFD8DC" RadiusX="5" RadiusY="5" Margin="0,0,0,5"/>
                                <TextBlock Text="Heavy Shield" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="40 gold" Foreground="Gray" HorizontalAlignment="Center"/>
                                <Button Content="ОБРАТИ" Background="#607D8B" Tag="HeavyShield" Click="OnSelectItemClick" Style="{StaticResource BuyButtonStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ShopCardStyle}">
                            <StackPanel>
                                <Rectangle Height="60" Fill="#E1BEE7" RadiusX="5" RadiusY="5" Margin="0,0,0,5"/>
                                <TextBlock Text="Mage Aura" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="70 gold" Foreground="Gray" HorizontalAlignment="Center"/>
                                <Button Content="ОБРАТИ" Background="#9C27B0" Tag="MageAura" Click="OnSelectItemClick" Style="{StaticResource BuyButtonStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ShopCardStyle}">
                            <StackPanel>
                                <Rectangle Height="60" Fill="#FFCDD2" RadiusX="5" RadiusY="5" Margin="0,0,0,5"/>
                                <TextBlock Text="Vampirism" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="60 gold" Foreground="Gray" HorizontalAlignment="Center"/>
                                <Button Content="ОБРАТИ" Background="#E91E63" Tag="Vampirism" Click="OnSelectItemClick" Style="{StaticResource BuyButtonStyle}"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <Button Content="❌ Скасувати вибір" Click="OnCancelSelectionClick" 
                        Background="#BDBDBD" Foreground="White" FontWeight="SemiBold"
                        HorizontalAlignment="Center" Margin="0,20,0,0" Padding="15,5"
                        Visibility="Visible">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="15"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        <TextBlock x:Name="InstructionText" Grid.Row="2" Text="ВАША АРМІЯ" 
                   FontSize="20" FontWeight="Bold" Foreground="#333" Margin="20,10,0,5"/>
        <ScrollViewer Grid.Row="3" Margin="10">
            <ListBox x:Name="ArmyListBox" 
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                 SelectionMode="Single"
                 SelectionChanged="OnUnitSelected"
                 Background="Transparent" BorderThickness="0">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder" Background="White" CornerRadius="10" Margin="5" Padding="5" Effect="{StaticResource ShadowEffect}" Width="160">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#4CAF50"/>
                                            <Setter TargetName="ItemBorder" Property="BorderThickness" Value="3"/>
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#E8F5E9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,5"/>
                            <TextBlock Text="{Binding Type}" FontStyle="Italic" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Rectangle Height="50" Width="50" RadiusX="25" RadiusY="25" Fill="#90A4AE" Margin="0,0,0,10"/>

                            <Grid Margin="10,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="HP" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Health}" FontWeight="Bold" Foreground="#D32F2F" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="ARM" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Armor}" FontWeight="Bold" Foreground="#1976D2" FontSize="14"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </Grid>
</Page>